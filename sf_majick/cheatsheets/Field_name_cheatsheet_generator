    "]\n",
    "import os\n",
    "\n",
    "# os.makedirs(\"cheatsheets\", exist_ok=True)\n",
    "\n",
    "for obj in objects_to_generate:\n",
    "    try:\n",
    "        df_fields = sfm.get_object_fields(obj, sf)\n",
    "        md_text = sfm.generate_md_cheatsheet(df_fields, obj)\n",
    "        \n",
    "        with open(f\"../cheatsheets/{obj}_cheatsheet.md\", \"w\") as f:\n",
    "            f.write(md_text)\n",
    "        \n",
    "        print(f\"{obj} cheatsheet created!\")\n",
    "    except requests.HTTPError as e:\n",
    "        if e.response.status_code == 404:\n",
